      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Toggle User Active",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/admin/users/2/toggle-active",
            "description": "Activate or deactivate a user account. Admin only. Deactivated users cannot log in."
          },
          "response": [
            {
              "name": "200 OK — Deactivated",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"User deactivated.\",\n  \"user\": { \"id\": 2, \"name\": \"Jane Doe\", \"is_active\": false }\n}"
            },
            {
              "name": "200 OK — Activated",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"User activated.\",\n  \"user\": { \"id\": 2, \"name\": \"Jane Doe\", \"is_active\": true }\n}"
            }
          ]
        },
        {
          "name": "Toggle Team Active",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{base_url}}/api/admin/teams/1/toggle-active",
            "description": "Activate or deactivate a team. Admin only."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Team deactivated.\",\n  \"team\": { \"id\": 1, \"name\": \"Engineering\", \"is_active\": false }\n}"
            }
          ]
        },
        {
          "name": "Toggle Category Active",
          "request": {
